# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
# Set True when served over HTTPS (nginx/TLS) so secure cookies are enabled.
# setup.sh sets this automatically; leave False ONLY for a bare-HTTP deploy.
USE_TLS=True

# Database Configuration
POSTGRES_DB=monitoring_db
POSTGRES_USER=monitoring_user
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# LLM Configuration (Ollama)
# Ollama runs as a Compose service -- use its service name, NOT localhost.
OLLAMA_API_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120
LLM_ENABLED=True
LLM_MAX_CALLS_PER_SCAN=2

# Initial admin
# The first administrator is created through the web setup form (/setup) on first run.

# Monitoring Configuration
DEFAULT_COLLECTION_INTERVAL=60
DEFAULT_RETENTION_DAYS=30
AGGREGATION_ENABLED=True

# Security
CSRF_TRUSTED_ORIGINS=https://localhost,http://localhost:8000
